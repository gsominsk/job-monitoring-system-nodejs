{
  "name": "job-monitoring-system",
  "version": "1.0.0",
  "description": "Cross-platform job monitoring system with process management and statistical analysis",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "NODE_ENV=development node src/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/e2e",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "lint": "echo 'Linting disabled for MVP - using native Node.js without external linters'",
    "seed": "node scripts/seed.js",
    "docker:build": "docker build -t job-monitoring-system:latest .",
    "docker:run": "docker run -p 3000:3000 --name job-monitor job-monitoring-system:latest",
    "docker:stop": "docker stop job-monitor && docker rm job-monitor",
    "docker:test": "docker build --target test -t job-monitoring-system:test .",
    "docker:compose:up": "docker-compose up -d",
    "docker:compose:down": "docker-compose down",
    "verify": "bash scripts/verify-deployment.sh"
  },
  "keywords": [
    "job-monitoring",
    "process-management",
    "statistics",
    "cross-platform"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
